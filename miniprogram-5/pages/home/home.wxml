<!--首页home.wxml-->
<view class="level bg-box">

	<!--搜索-->
	<view class="am-search-wrap">
		<view class="am-search-bar">
			<icon class="am-search-icon" type="search" size="16"></icon>
			<picker mode="selector" range="{{searchTypes}}" value="{{searchTypeIndex}}" bindchange="onSearchTypeChange">
				<view class="am-search-filter">
					<text class="am-search-filter-text">{{searchTypes[searchTypeIndex]}}</text>
					<text class="am-search-filter-caret">▾</text>
				</view>
			</picker>
			<view class="am-search-divider"></view>
			<input placeholder="输入关键字" class="am-search-input" value="{{keyword}}" confirm-type="search" bindinput="onKeywordInput" bindconfirm="doSearch" />
			<text class="am-search-action" bindtap="doSearch">搜索</text>
    </view>
  </view>

 <!--轮播图-->
  <swiper>
    <swiper-item>
      <view class="item">
        <image src="https://tse1-mm.cn.bing.net/th/id/OIP-C.iwiM6mKmcmYoMaQSarkt3AHaDt?rs=1&pid=ImgDetMain" mode="aspectFill"></image>
      </view>
    </swiper-item>
    <swiper-item>
      <view class="item">
        <image src="https://photo-static-api.fotomore.com/creative/vcg/veer/612/veer-302781152.jpg" mode="aspectFill"></image>
      </view>
    </swiper-item>
    <swiper-item>
      <view class="item">
        <image src="https://tse4-mm.cn.bing.net/th/id/OIP-C.vJL3lt6xBU6H9GedCxaz3AHaDt?rs=1&pid=ImgDetMain"  mode="aspectFill"></image>
      </view>
    </swiper-item>
  </swiper>
  <!--公告栏-->
  <view class="tip-box level" bindtap="onTapNotice">
    <view class="tip-title">公告</view>
    <view class="tip-info">{{notices.length ? notices[0].Title : '欢迎使用随心游小程序~'}}</view>
  </view>

</view>
  
