<view class="level tab-box">
        <block >
            <block wx:for="{{tabList}}" wx:key="id">
              <navigator wx:if="{{item.url}}" url="{{item.url}}" class="tab-list">
                <image class="tab-img" src="{{item.src}}" mode="widthFix"></image>
                <text class="tab-text">{{item.title}}</text>
              </navigator>
              <view wx:else class="tab-list" data-id="{{item.id}}" bindtap="onTapTab">
                <image class="tab-img" src="{{item.src}}" mode="widthFix"></image>
                <text class="tab-text">{{item.title}}</text>
              </view>
            </block>
        </block>
</view>
<!--推荐卡片-->
<view class=" rec-box">
  <view class="level">
    <view class="line"></view>
    <view class="title">文章推荐</view>
  </view>
  <view class="article-list" wx:for="{{recommendPosts}}" wx:key="ID" bindtap="toPostDetail" data-id="{{item.ID}}">
		<view class="row-right">
			<image src="{{item.HeadImg || '../../icon/旅游攻略.png'}}" class="row-img" mode="aspectFill"></image>
		</view>
		<view class="row-left">
			<view class="row-left-title">{{item.Title}}</view>
			<view class="row-left-content">{{item.Content}}</view>
		</view>     
	</view>
</view>
<!--编写按钮-->
<navigator class="btn" url="../article/article" >
  <image src="../../icon/Pencil.png" mode="aspectFill" class="btn-img"/>
</navigator>
