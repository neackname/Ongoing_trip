page {
  background: #ffffff;
}

.page {
  min-height: 100vh;
  background: #ffffff;
  padding: 24rpx;
  box-sizing: border-box;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
  line-height: 44rpx;
}

.card-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #666666;
  line-height: 38rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #9aa0a6;
}

.meta-arrow {
  margin-left: auto;
  font-size: 36rpx;
  color: #c6cacc;
}

.empty {
  padding: 140rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.7;
}

.empty-title {
  margin-top: 22rpx;
  font-size: 30rpx;
  color: #111111;
  font-weight: 600;
}

.empty-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #9aa0a6;
}
