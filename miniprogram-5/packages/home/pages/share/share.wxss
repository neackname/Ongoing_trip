/* packages/home/pages/share/share.wxss */

page{
  background-color: #f5f7fb;
}

.page{
  min-height: 100%;
  background-color: #f5f7fb;
}

.list{
  padding: 24rpx;
}

.post{
  width: 100%;
  height: 176rpx;
  background-color: #ffffff;
  border-radius: 18rpx;
  padding: 18rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
  box-shadow: 0 10rpx 30rpx rgba(16, 24, 40, 0.06);
}

.post-image{
  width: 176rpx;
  height: 140rpx;
  border-radius: 14rpx;
  background-color: #eef1f6;
  flex-shrink: 0;
}

.post-content{
  flex: 1;
  min-width: 0;
  height: 140rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.post-snippet{
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.post-meta{
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.post-avatar{
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background-color: #eef1f6;
}

.post-nickname{
  font-size: 24rpx;
  color: #4b5563;
  max-width: 200rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.post-time{
  font-size: 22rpx;
  color: #9aa0a6;
}
