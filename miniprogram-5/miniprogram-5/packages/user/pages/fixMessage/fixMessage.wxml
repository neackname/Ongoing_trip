<!--pages/user/fixMessage/fixMessage.wxml-->
<view class="page">
  <view class="card">
    <button open-type="chooseAvatar" class="row" bind:chooseavatar="onChooseAvatar">
      <view class="left">
        <text class="text">头像</text>
      </view>
      <view class="right">
        <image src="{{userInfo.avatar}}" class="img" mode="aspectFill"/>
      </view>
    </button>
    <view class="row">
      <view class="left">
        <text class="text">昵称</text>
      </view>
      <view class="right">
        <input class="input" type="nickname" placeholder="{{userInfo.nickname}}" bind:blur="onInputChange" />
      </view>
    </view>
    <view class="row">
      <view class="left">
        <text class="text">个性签名（非必填）</text>
      </view>
      <view class="right">
        <input class="input" type="text" placeholder="{{userInfo.motto}}" bind:blur="onInputChangeMotto" />
      </view>
    </view>
    <view class="row">
      <view class="left">
        <text class="text">性别</text>
      </view>
      <view class="right">
        <input class="input" type="text" placeholder="{{userInfo.gender}}" bind:blur="onInputChangeGender" />
      </view>
    </view>
    <view class="row row-last">
      <view class="left">
        <text class="text">手机号</text>
      </view>
      <view class="right">
        <input class="input" type="text" placeholder="{{userInfo.telephone}}" bind:blur="onInputChangeTelephone" />
      </view>
    </view>
  </view>
  <button class="submit-btn" bindtap="updateUserInfo">保存</button>
</view>
